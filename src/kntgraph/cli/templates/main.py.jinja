    print("Starting {{ project_name }} Modular Monolith...")
    
    redis = create_redis_pool().client
    log = EventLog(RedisEventLogAdapter(client=redis))
    
    # 1. Initialize the ToolRouter (Fan-out for impure tools)
    tool_router = ToolRouter(redis)
    
    # 2. Initialize the WorkerManager (Execution pool for tools)
