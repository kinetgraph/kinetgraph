class CollaborationCoordinator:
    """Coordinator for collaborative routing flows."""

    def __init__(self, routing_mode: str = "collaborate") -> None:
        self.routing_mode = routing_mode

    def select_agent(self, intent: str) -> str:
        return f"agent:{intent}"
