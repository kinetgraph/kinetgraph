    # sales_dispatcher = build_sales_dispatcher(log, redis, tool_router)
    # logistics_dispatcher = build_logistics_dispatcher(log, redis, tool_router)
    
    try:
        print("\n[Orchestrator] Starting Event Loops...")
        # 4. Start everything concurrently in the same asyncio Event Loop
        await asyncio.gather(
            worker_manager.start(),
            # sales_dispatcher.start(),
            # logistics_dispatcher.start()
        )
    finally:
        print("\n[Orchestrator] Stopping components...")
        # await sales_dispatcher.stop()
        # await logistics_dispatcher.stop()
        await worker_manager.stop()
        await redis.aclose()

if __name__ == "__main__":
    asyncio.run(main())
