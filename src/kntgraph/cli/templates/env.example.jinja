# Kinetgraph configuration
KNT_ENV=dev
KNT_REDIS_URL=redis://localhost:6379

# Graph DB (FalkorDB)
KNT_FALKORDB_HOST=localhost
KNT_FALKORDB_PORT=16379
KNT_FALKORDB_PASSWORD=falkordb

# Stream & Checkpoint limits
KNT_STREAM_MAXLEN=100000
KNT_GLOBAL_STREAM_MAXLEN=1000000
KNT_TICK_INTERVAL=1.0

# LLM Config
KNT_LLM_DEFAULT_MODEL=llama3.1:latest
KNT_LLM_TIMEOUT=30.0
KNT_LLM_MAX_COST_USD_PER_REQUEST=0.05

# Resilience
KNT_CIRCUIT_BREAKER_THRESHOLD=5
KNT_RETRY_MAX_ATTEMPTS=3

# Gateway Config
KNT_API_URL=http://localhost:8000
KNT_API_KEY=

# Knowledge & GraphRAG
KNT_KNOWLEDGE_INTERVAL_S=10.0
KNT_PII_LEVEL=1
KNT_SOLUTIONS_TOOL_ALLOWLIST=
KNT_SOLUTIONS_CONFIDENCE_BUMP_AGENTS=2
KNT_SOLUTIONS_REVIEW_TTL_S=604800
KNT_SOLUTIONS_REVIEW_THRESHOLD=1
