from kntgraph.runner import ReactiveDispatcher
from kntgraph.stream.event_log import EventLog
from kntgraph.tools.registry import ToolRegistry

# Import all systems and tools from your context's agents here.
# For example:
# from .agents.checkout_agent import get_checkout_agent_systems, get_checkout_agent_tools

def build_{{ context_name }}_dispatcher(log: EventLog) -> ReactiveDispatcher:
    """
    Orchestrates the ReactiveDispatcher for the entire '{{ context_name }}' context.
    Aggregates pure WorldSystems and impure Tools from all its Agents.
    """

    # 1. Aggregate Tools
    # tools = get_checkout_agent_tools() + ...
    tools = []

    # 2. Register tools (per the ``ToolRegistry`` contract;
    # the legacy ``IntentResolutionSystem`` ACL gate was
    # removed in v0.9.0; per-tool ACL is enforced by
    # the ``ToolACL`` at the ``ToolRegistry`` level).
    registry = ToolRegistry()
    for tool in tools:
        registry.register(tool)

    # 3. Aggregate Systems. The legacy
    # ``IntentResolutionSystem`` (kntgraph.agents.roles)
    # was removed in v0.9.0 (ADR-039). The new
    # architecture wires per-role ``WorldSystem``
    # instances (e.g. ``ChatRoleSystem`` /
    # ``PlannerRoleSystem`` from
    # ``kntgraph.agents.role_systems``) directly into
    # the dispatcher; the systems themselves emit
    # ``tool.<name>.requested`` events that the
    # ``WorkerManager`` orchestrates.
    # systems = get_checkout_agent_systems() + ...
    systems = []

    # 4. Create the dispatcher
    dispatcher = ReactiveDispatcher(
        log=log,
        systems=systems,
    )

    return dispatcher
