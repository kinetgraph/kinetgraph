from ..coordinator import CollaborationCoordinator


def build_adapter(*, routing_mode: str = "collaborate"):
    """Build the collaborative routing adapter."""

    coordinator = CollaborationCoordinator(routing_mode=routing_mode)
    return {"mode": routing_mode, "kind": "collaborate", "coordinator": coordinator}
